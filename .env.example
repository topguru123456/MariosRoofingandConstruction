# Copy to .env and adjust for your environment.

# Public site URL (no trailing slash). Used for canonical, OG tags, and schema.
VITE_SITE_URL=https://mariosroofingandconstruction.com

# Resend — server-side only (never prefix with VITE_)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Verified sender in Resend (domain must be verified for production).
# Example: Mario's Roofing & Construction <inquiries@mariosroofingandconstruction.com>
RESEND_FROM_EMAIL=Mario's Roofing & Construction <onboarding@resend.dev>

# Where new inquiry alerts are delivered
INQUIRY_NOTIFY_EMAIL=abcsconst@gmail.com
